{
  "manifest_version": 3,
  "name": "HumanTrace",
  "version": "1.0.0",
  "description": "Tells you if a real human sent that message — before you respond. Powered by Owlume.",

  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "http://localhost:8000/*",
    "http://192.168.*.*:8000/*",
    "https://humantrace.au/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "HumanTrace — Scan for synthetic fraud"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
